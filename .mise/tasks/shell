#!/usr/bin/env bash
#MISE description="Output shell configuration (PATH, env vars) for eval"
set -eo pipefail

REPO_DIR="$MISE_CONFIG_ROOT"
source "$REPO_DIR/lib/shim.sh"

# Self-hosting: bootstrap shiv into packages/ if not already registered
shiv_init_registry
EXISTING_SHIV=$(shiv_registry_path "shiv")
if [ -z "$EXISTING_SHIV" ]; then
  # First time: shiv isn't registered yet — bootstrap it
  SHIV_CANONICAL="$SHIV_PACKAGES_DIR/shiv"
  if [ "$REPO_DIR" != "$SHIV_CANONICAL" ] && [ ! -d "$SHIV_CANONICAL" ]; then
    mkdir -p "$SHIV_PACKAGES_DIR"
    REMOTE=$(git -C "$REPO_DIR" remote get-url origin 2>/dev/null || echo "")
    if [ -n "$REMOTE" ]; then
      git clone "$REMOTE" "$SHIV_CANONICAL" >/dev/null 2>&1
    else
      cp -R "$REPO_DIR" "$SHIV_CANONICAL"
    fi
  fi
  shiv_create_shim "shiv" "$SHIV_CANONICAL"
  shiv_register "shiv" "$SHIV_CANONICAL"
  shiv_cache_tasks "shiv" "$SHIV_CANONICAL"
fi

# Ensure ~/.local/bin is on PATH (skip if already there)
case ":$PATH:" in
  *":$SHIV_BIN_DIR:"*) ;;
  *) echo "export PATH=\"$SHIV_BIN_DIR:\$PATH\"" ;;
esac

# Ensure mise shims are on PATH so shiv packages installed via vfox-shiv
# resolve correctly in non-interactive shells (agent sessions, scripts, etc.).
# Emitted after SHIV_BIN_DIR so shims end up earlier on PATH — when a
# directory's mise.toml pins a version, the mise shim wins over the global shiv shim.
MISE_SHIMS_DIR="${MISE_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/mise}/shims"
if [ -d "$MISE_SHIMS_DIR" ]; then
  case ":$PATH:" in
    *":$MISE_SHIMS_DIR:"*) ;;
    *) echo "export PATH=\"$MISE_SHIMS_DIR:\$PATH\"" ;;
  esac
fi

# Export SHIV_SOURCES if sources directory has files
if [ -n "$SHIV_SOURCES" ]; then
  echo "export SHIV_SOURCES=\"$SHIV_SOURCES\""
fi

# Auto-include shell completions
SHIV_PATH=$(shiv_registry_path "shiv")
if [ -n "$SHIV_PATH" ]; then
  DETECTED_SHELL="$(basename "${SHELL:-bash}")"
  case "$DETECTED_SHELL" in
    bash|zsh|fish)
      echo "eval \"\$(mise -C '$SHIV_PATH' run -q completions:$DETECTED_SHELL)\""
      ;;
  esac
fi
