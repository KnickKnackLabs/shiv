#!/usr/bin/env bash
#MISE description="Output shell configuration for all managed tools (use with eval)"
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

# Self-hosting: shiv lives in packages/shiv like every other package
SHIV_CANONICAL="$SHIV_PACKAGES_DIR/shiv"
if [ "$REPO_DIR" != "$SHIV_CANONICAL" ]; then
  # Bootstrap: running from an external clone — install shiv into packages/
  if [ ! -d "$SHIV_CANONICAL" ]; then
    mkdir -p "$SHIV_PACKAGES_DIR"
    REMOTE=$(git -C "$REPO_DIR" remote get-url origin 2>/dev/null || echo "")
    if [ -n "$REMOTE" ]; then
      git clone "$REMOTE" "$SHIV_CANONICAL" >/dev/null 2>&1
    else
      cp -R "$REPO_DIR" "$SHIV_CANONICAL"
    fi
  fi
fi
shiv_create_shim "shiv" "$SHIV_CANONICAL"
shiv_register "shiv" "$SHIV_CANONICAL"

# Ensure ~/.local/bin is on PATH (skip if already there)
case ":$PATH:" in
  *":$SHIV_BIN_DIR:"*) ;;
  *) echo "export PATH=\"$SHIV_BIN_DIR:\$PATH\"" ;;
esac
