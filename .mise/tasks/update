#!/usr/bin/env bash
#MISE description="Refresh all shims from the registry"
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

shiv_init_registry

COUNT=$(jq 'length' "$SHIV_REGISTRY")

if [ "$COUNT" -eq 0 ]; then
  echo "No tools registered."
  exit 0
fi

echo "Updating $COUNT tool(s)..."

shiv_registry_entries | while IFS=$'\t' read -r name repo; do
  if [ -d "$repo" ]; then
    if git -C "$repo" pull --ff-only >/dev/null 2>&1; then
      shiv_create_shim "$name" "$repo"
      echo "  ✓ $name → $repo"
    else
      shiv_create_shim "$name" "$repo"
      echo "  ⚠ $name → $repo (pull failed, shim refreshed)"
    fi
    shiv_cache_tasks "$name" "$repo"

    # Recreate alias symlinks
    mapfile -t aliases < <(shiv_registry_aliases "$name")
    if [ ${#aliases[@]} -gt 0 ]; then
      shiv_create_alias_symlinks "$name" "${aliases[@]}"
      echo "    aliases: ${aliases[*]}"
    fi
  else
    echo "  ✗ $name — repo not found at $repo (skipped)"
  fi
done

echo "Done."
