#!/usr/bin/env bash
#MISE description="Check health of all managed tools"
set -eo pipefail

REPO_DIR="$MISE_CONFIG_ROOT"
source "$REPO_DIR/lib/shim.sh"

shiv_init_registry

SEP='|'
HAS_ISSUES=false

# ── Header ──────────────────────────────────────────────────────

COUNT=$(jq 'length' "$SHIV_REGISTRY")

# Schema validation
schema_status="✓ valid ($COUNT packages)"
if command -v jsonschema &>/dev/null; then
  if ! jsonschema validate "$REPO_DIR/registry.schema.json" "$SHIV_REGISTRY" 2>/dev/null; then
    schema_status="✗ invalid — run 'shiv registry:validate'"
    HAS_ISSUES=true
  fi
else
  schema_status="- skipped (jsonschema not found)"
fi

# Bin dir check
bin_status="✓ $SHIV_BIN_DIR"
if [ ! -d "$SHIV_BIN_DIR" ]; then
  bin_status="✗ $SHIV_BIN_DIR (not found)"
  HAS_ISSUES=true
fi

echo ""
gum style --bold "  SHIV HEALTH"
echo ""
{
  echo "Registry${SEP}${schema_status}"
  echo "Bin dir${SEP}${bin_status}"
} | gum table -s "$SEP" -c "CHECK,STATUS" -p --border normal

# ── Per-package checks ──────────────────────────────────────────

if [ "$COUNT" -eq 0 ]; then
  echo ""
  echo "  No tools registered."
else
  echo ""
  gum style --bold "  PACKAGES"
  echo ""

  rows=()
  issue_names=()
  issue_details=()

  while IFS=$'\t' read -r name repo _ref; do
    issues=""
    issue_count=0

    # Check repo exists
    if [ ! -d "$repo" ]; then
      issues+="    ✗ repo not found at $repo"$'\n'
      issue_count=$((issue_count + 1))
    fi

    # Check shim exists and is managed by shiv
    if [ ! -f "$SHIV_BIN_DIR/$name" ]; then
      issues+="    ✗ shim missing at $SHIV_BIN_DIR/$name"$'\n'
      issue_count=$((issue_count + 1))
    elif ! grep -q "# managed by shiv" "$SHIV_BIN_DIR/$name" 2>/dev/null; then
      issues+="    ✗ shim exists but not managed by shiv"$'\n'
      issue_count=$((issue_count + 1))
    fi

    # Check shim points to right repo
    if [ -f "$SHIV_BIN_DIR/$name" ]; then
      shim_repo=$(grep '^REPO=' "$SHIV_BIN_DIR/$name" 2>/dev/null | cut -d'"' -f2 || true)
      if [ -n "$shim_repo" ] && [ "$shim_repo" != "$repo" ]; then
        issues+="    ✗ shim points to $shim_repo but registry says $repo"$'\n'
        issue_count=$((issue_count + 1))
      fi
    fi

    # Check alias symlinks
    aliases=()
    while IFS= read -r _alias; do
      [ -n "$_alias" ] && aliases+=("$_alias")
    done < <(shiv_registry_aliases "$name")
    for alias in "${aliases[@]}"; do
      if [ ! -L "$SHIV_BIN_DIR/$alias" ]; then
        issues+="    ✗ alias symlink missing: $SHIV_BIN_DIR/$alias"$'\n'
        issue_count=$((issue_count + 1))
      elif [ "$(readlink "$SHIV_BIN_DIR/$alias")" != "$name" ]; then
        issues+="    ✗ alias symlink $alias points to wrong target"$'\n'
        issue_count=$((issue_count + 1))
      fi
    done

    if [ "$issue_count" -gt 0 ]; then
      rows+=("${name}${SEP}✗ (${issue_count})")
      issue_names+=("$name")
      issue_details+=("$issues")
      HAS_ISSUES=true
    else
      rows+=("${name}${SEP}✓")
    fi
  done < <(shiv_registry_entries)

  # Package table
  printf '%s\n' "${rows[@]}" | gum table -s "$SEP" -c "PACKAGE,STATUS" -p --border normal

  # Issue details
  if [ ${#issue_names[@]} -gt 0 ]; then
    echo ""
    for i in "${!issue_names[@]}"; do
      gum style --bold "  ${issue_names[$i]}:"
      printf '%s' "${issue_details[$i]}"
    done
  fi
fi

# ── Orphaned shims ────────────────────────────────────────────

orphaned=()
if [ -d "$SHIV_BIN_DIR" ]; then
  for shim in "$SHIV_BIN_DIR"/*; do
    [ -f "$shim" ] || continue
    [ -L "$shim" ] && continue
    grep -q "# managed by shiv" "$shim" 2>/dev/null || continue
    shim_name=$(basename "$shim")
    # Skip if registered
    if jq -e --arg n "$shim_name" 'has($n)' "$SHIV_REGISTRY" &>/dev/null; then
      continue
    fi
    orphaned+=("$shim_name")
  done
fi

if [ ${#orphaned[@]} -gt 0 ]; then
  echo ""
  gum style --bold "  ORPHANED SHIMS"
  echo ""
  for name in "${orphaned[@]}"; do
    echo "    ✗ $SHIV_BIN_DIR/$name"
  done
  echo ""
  gum style --faint "  These shims reference shiv but have no registry entry."
  gum style --faint "  Remove with: rm \$shim_path"
  HAS_ISSUES=true
fi

if [ "$HAS_ISSUES" = "true" ]; then
  exit 1
fi
