#!/usr/bin/env bash
#MISE description="Output fish completion script"
#MISE hide=true
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}"/)/../../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

shiv_init_registry

CACHE_BASE="$SHIV_CACHE_DIR/completions"

cat <<'HEADER'
# shiv shell completions for fish
# Generated by: shiv completions fish

function __shiv_rebuild_cache
  set -l name $argv[1]
  set -l repo $argv[2]
  set -l cache $argv[3]
  mkdir -p (dirname "$cache")
  mise tasks --json -C "$repo" 2>/dev/null \
    | jq -r '.[] | select(.hide == false) | "\(.name)\t\(.description)"' \
    > "$cache" 2>/dev/null; or true
end

HEADER

jq -r 'to_entries[] | "\(.key) \(.value)"' "$SHIV_REGISTRY" | while read -r name repo; do
  cache_file="$CACHE_BASE/$name.cache"

  cat <<EOF
# completions for: ${name}
complete -c ${name} -f -a '(begin
  set -l cache "${cache_file}"
  if not test -f "\$cache"
    __shiv_rebuild_cache "$name" "$repo" "\$cache"
  end
  if test -f "\$cache"
    cat "\$cache" | while read -l line
      string split -m 1 "\\t" -- \$line | string join "\\t"
    end
  end
end)'

EOF
done
