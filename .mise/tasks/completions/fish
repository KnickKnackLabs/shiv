#!/usr/bin/env bash
#MISE description="Output fish completion script"
#MISE hide=true
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/shim.sh"

shiv_init_registry

CACHE_BASE="$SHIV_CACHE_DIR/completions"

cat <<'HEADER'
# shiv shell completions for fish
# Generated by: shiv completions fish

function __shiv_rebuild_cache
  set -l name $argv[1]
  set -l repo $argv[2]
  set -l cache $argv[3]
  mkdir -p (dirname "$cache")
  mise tasks --json -C "$repo" 2>/dev/null \
    | jq -r '.[] | select(.hide == false) | "\(.name)\t\(.description)"' \
    > "$cache" 2>/dev/null; or true
end

HEADER

# Emit completion block for a command name pointing at a repo
_shiv_emit_fish_completion() {
  local cmd="$1" name="$2" repo="$3"
  local cache_file="$CACHE_BASE/$name.cache"

  cat <<EOF
# completions for: ${cmd}
complete -c ${cmd} -f -a '(begin
  set -l cache "${cache_file}"
  if not test -s "\$cache"
    __shiv_rebuild_cache "$name" "$repo" "\$cache"
  end
  if test -f "\$cache"
    cat "\$cache"
  end
end)'

EOF
}

shiv_registry_entries | while IFS=$'\t' read -r name repo; do
  _shiv_emit_fish_completion "$name" "$name" "$repo"

  while IFS= read -r alias; do
    [ -n "$alias" ] || continue
    _shiv_emit_fish_completion "$alias" "$name" "$repo"
  done < <(shiv_registry_aliases "$name")
done
