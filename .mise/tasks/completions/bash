#!/usr/bin/env bash
#MISE description="Output bash completion script"
#MISE hide=true
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}"/)/../../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

shiv_init_registry

CACHE_BASE="$SHIV_CACHE_DIR/completions"

cat <<'HEADER'
# shiv shell completions for bash
# Generated by: shiv completions bash

__shiv_rebuild_cache() {
  local name="$1" repo="$2" cache="$3"
  mkdir -p "$(dirname "$cache")"
  mise tasks --json -C "$repo" 2>/dev/null \
    | jq -r '.[] | select(.hide == false) | "\(.name)\t\(.description)"' \
    > "$cache" 2>/dev/null || true
}

HEADER

jq -r 'to_entries[] | "\(.key) \(.value)"' "$SHIV_REGISTRY" | while read -r name repo; do
  cache_file="$CACHE_BASE/$name.cache"

  func_name="${name//-/_}"

  cat <<EOF
_shiv_complete_${func_name}() {
  local cache="${cache_file}"
  if [[ ! -s "\$cache" ]]; then
    __shiv_rebuild_cache "$name" "$repo" "\$cache"
  fi
  if [[ -f "\$cache" ]]; then
    local cur="\${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=( \$(cut -f1 "\$cache" | grep "^\$cur") )
  fi
}
complete -F _shiv_complete_${func_name} ${name}

EOF
done
