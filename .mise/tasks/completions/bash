#!/usr/bin/env bash
#MISE description="Output bash completion script"
#MISE hide=true
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}"/)/../../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

shiv_init_registry

CACHE_BASE="$SHIV_CACHE_DIR/completions"

cat <<'HEADER'
# shiv shell completions for bash
# Generated by: shiv completions bash

__shiv_rebuild_cache() {
  local name="$1" repo="$2" cache="$3"
  mkdir -p "$(dirname "$cache")"
  mise tasks --json -C "$repo" 2>/dev/null \
    | jq -r '.[] | select(.hide == false) | "\(.name)\t\(.description)"' \
    > "$cache" 2>/dev/null || true
}

HEADER

# Emit completion function for a command name pointing at a repo
_shiv_emit_bash_completion() {
  local cmd="$1" name="$2" repo="$3"
  local cache_file="$CACHE_BASE/$name.cache"
  local func_name="${cmd//[^a-zA-Z0-9_]/_}"

  cat <<EOF
_shiv_complete_${func_name}() {
  local cache="${cache_file}"
  if [[ ! -s "\$cache" ]]; then
    __shiv_rebuild_cache "$name" "$repo" "\$cache"
  fi
  if [[ -f "\$cache" ]]; then
    local cur="\${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=( \$(compgen -W "\$(cut -f1 "\$cache")" -- "\$cur") )
  fi
}
complete -F _shiv_complete_${func_name} ${cmd}

EOF
}

shiv_registry_entries | while IFS=$'\t' read -r name repo; do
  # Completion for the package name
  _shiv_emit_bash_completion "$name" "$name" "$repo"

  # Completions for aliases (reuse the same cache)
  while IFS= read -r alias; do
    [ -n "$alias" ] || continue
    _shiv_emit_bash_completion "$alias" "$name" "$repo"
  done < <(shiv_registry_aliases "$name")
done
