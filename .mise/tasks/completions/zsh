#!/usr/bin/env bash
#MISE description="Output zsh completion script"
#MISE hide=true
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/shim.sh"

shiv_init_registry

CACHE_BASE="$SHIV_CACHE_DIR/completions"

# Helper function embedded in the completion script — rebuilds cache on the fly
# if it's missing (e.g. user cleared ~/.cache). Avoids needing to source shim.sh
# at completion time.
cat <<'HEADER'
# shiv shell completions for zsh
# Generated by: shiv completions zsh

__shiv_rebuild_cache() {
  local name="$1" repo="$2" cache="$3"
  mkdir -p "$(dirname "$cache")"
  if ! mise tasks --json -C "$repo" 2>/dev/null \
    | jq -r '.[] | select(.hide == false) | "\(.name)\t\(.description)"' \
    > "$cache" 2>/dev/null; then
    rm -f "$cache"
  fi
}

HEADER

# Emit completion function for a command name pointing at a repo
_shiv_emit_zsh_completion() {
  local cmd="$1" name="$2" repo="$3"
  local cache_file="$CACHE_BASE/$name.cache"
  local func_name="${cmd//[^a-zA-Z0-9_]/_}"

  cat <<EOF
_shiv_complete_${func_name}() {
  local cache="${cache_file}"
  if [[ ! -s "\$cache" ]]; then
    __shiv_rebuild_cache "$name" "$repo" "\$cache"
  fi
  if [[ -f "\$cache" ]]; then
    local -a completions
    while IFS=\$'\\t' read -r task desc; do
      # Escape colons in task names — _describe uses : as value/description separator
      local escaped="\${task//:/\\\\:}"
      completions+=("\${escaped}:\${desc}")
    done < "\$cache"
    _describe 'tasks' completions
  fi
}
compdef _shiv_complete_${func_name} ${cmd}

EOF
}

# Emit a completion function for each registered tool
shiv_registry_entries | while IFS=$'\t' read -r name repo; do
  _shiv_emit_zsh_completion "$name" "$name" "$repo"

  while IFS= read -r alias; do
    [ -n "$alias" ] || continue
    _shiv_emit_zsh_completion "$alias" "$name" "$repo"
  done < <(shiv_registry_aliases "$name")
done
