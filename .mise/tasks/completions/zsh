#!/usr/bin/env bash
#MISE description="Output zsh completion script"
#MISE hide=true
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}"/)/../../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

shiv_init_registry

CACHE_BASE="$SHIV_CACHE_DIR/completions"

# Helper function embedded in the completion script — rebuilds cache on the fly
# if it's missing (e.g. user cleared ~/.cache). Avoids needing to source shim.sh
# at completion time.
cat <<'HEADER'
# shiv shell completions for zsh
# Generated by: shiv completions zsh

__shiv_rebuild_cache() {
  local name="$1" repo="$2" cache="$3"
  mkdir -p "$(dirname "$cache")"
  mise tasks --json -C "$repo" 2>/dev/null \
    | jq -r '.[] | select(.hide == false) | "\(.name)\t\(.description)"' \
    > "$cache" 2>/dev/null || true
}

HEADER

# Emit a completion function for each registered tool
jq -r 'to_entries[] | "\(.key) \(.value)"' "$SHIV_REGISTRY" | while read -r name repo; do
  cache_file="$CACHE_BASE/$name.cache"

  # Sanitize name for use as a shell function identifier
  func_name="${name//[^a-zA-Z0-9_]/_}"

  cat <<EOF
_shiv_complete_${func_name}() {
  local cache="${cache_file}"
  if [[ ! -s "\$cache" ]]; then
    __shiv_rebuild_cache "$name" "$repo" "\$cache"
  fi
  if [[ -f "\$cache" ]]; then
    local -a completions
    while IFS=\$'\\t' read -r task desc; do
      # Escape colons in task names — _describe uses : as value/description separator
      local escaped="\${task//:/\\\\:}"
      completions+=("\${escaped}:\${desc}")
    done < "\$cache"
    _describe 'tasks' completions
  fi
}
compdef _shiv_complete_${func_name} ${name}

EOF
done
