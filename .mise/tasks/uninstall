#!/usr/bin/env bash
#MISE description="Remove a tool's shim and deregister it"
#USAGE arg "<name>" help="Package name to remove"
#USAGE flag "-y --yes" help="Skip confirmation prompt"
#USAGE flag "--force" help="Override safety checks (e.g., uninstalling shiv)"
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

NAME="${usage_name}"
YES="${usage_yes:-false}"
FORCE="${usage_force:-false}"

# --force implies --yes
if [ "$FORCE" = "true" ]; then
  YES="true"
fi

shiv_init_registry

# Self-uninstall safety check
if [ "$NAME" = "shiv" ] && [ "$FORCE" != "true" ]; then
  OTHER_COUNT=$(jq '[keys[] | select(. != "shiv")] | length' "$SHIV_REGISTRY")
  if [ "$OTHER_COUNT" -gt 0 ]; then
    gum log -l error "$OTHER_COUNT package(s) still installed — use --force to uninstall shiv anyway"
    exit 1
  fi
fi

# Confirm before proceeding (unless -y or --force)
if [ "$YES" != "true" ]; then
  gum confirm "Uninstall $NAME?" || { echo "Cancelled."; exit 0; }
fi

# Resolve aliases before removing anything
mapfile -t ALIASES < <(shiv_registry_aliases "$NAME")

# Remove alias symlinks
if [ ${#ALIASES[@]} -gt 0 ]; then
  shiv_remove_alias_symlinks "$NAME" "${ALIASES[@]}"
  gum log -l info "Removed aliases: ${ALIASES[*]}"
fi

# Remove shim
if [ -f "$SHIV_BIN_DIR/$NAME" ]; then
  rm "$SHIV_BIN_DIR/$NAME"
  gum log -l info "Removed shim: $SHIV_BIN_DIR/$NAME"
else
  gum log -l warn "No shim found for $NAME"
fi

# Deregister
shiv_unregister "$NAME"
shiv_cache_remove "$NAME"
gum log -l info "Unregistered: $NAME"
