#!/usr/bin/env bash
#MISE description="Remove a tool's shim and deregister it"
#USAGE arg "<name>" help="Package name to remove"
#USAGE flag "-y --yes" help="Skip confirmation prompt"
#USAGE flag "--force" help="Override safety checks (e.g., uninstalling shiv)"
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

NAME="${usage_name}"
YES="${usage_yes:-false}"
FORCE="${usage_force:-false}"
SEP='|'

# --force implies --yes
if [ "$FORCE" = "true" ]; then
  YES="true"
fi

shiv_init_registry

# Check package is registered
if [ -z "$(shiv_registry_path "$NAME")" ]; then
  echo "  ✗ '$NAME' is not a registered package" >&2
  exit 1
fi

# Self-uninstall safety check
if [ "$NAME" = "shiv" ] && [ "$FORCE" != "true" ]; then
  OTHER_COUNT=$(jq '[keys[] | select(. != "shiv")] | length' "$SHIV_REGISTRY")
  if [ "$OTHER_COUNT" -gt 0 ]; then
    echo ""
    echo "  Can't uninstall shiv — $OTHER_COUNT package(s) still installed:"
    echo ""

    while IFS=$'\t' read -r pkg_name pkg_path; do
      if [ "$pkg_name" != "shiv" ]; then
        printf '%s\n' "${pkg_name}${SEP}${pkg_path}"
      fi
    done < <(shiv_registry_entries) | gum table -s "$SEP" -c "PACKAGE,PATH" -p --border normal

    echo ""
    gum style --faint "  Use --force to uninstall shiv anyway."
    exit 1
  fi
fi

# Gather metadata for summary card
TOOL_PATH=$(shiv_registry_path "$NAME")
mapfile -t ALIASES < <(shiv_registry_aliases "$NAME")

# Annotate PATH and SHIM with "(not found)" if missing
path_display="${TOOL_PATH:--}"
if [ -n "$TOOL_PATH" ] && [ ! -d "$TOOL_PATH" ]; then
  path_display="$TOOL_PATH (not found)"
fi

shim_display="$SHIV_BIN_DIR/$NAME"
if [ ! -f "$SHIV_BIN_DIR/$NAME" ]; then
  shim_display="$SHIV_BIN_DIR/$NAME (not found)"
fi

alias_display="${ALIASES[*]}"
alias_display="${alias_display:--}"

# Show summary card
echo ""
{
  echo "PACKAGE${SEP}${NAME}"
  echo "PATH${SEP}${path_display}"
  echo "SHIM${SEP}${shim_display}"
  echo "ALIASES${SEP}${alias_display}"
} | gum table -s "$SEP" -c "KEY,VALUE" -p --border normal

# Confirm before proceeding (unless -y or --force)
if [ "$YES" != "true" ]; then
  echo ""
  "${GUM:-gum}" confirm "Proceed?" || { echo "Cancelled."; exit 0; }
fi

# Remove alias symlinks
if [ ${#ALIASES[@]} -gt 0 ]; then
  shiv_remove_alias_symlinks "$NAME" "${ALIASES[@]}"
fi

# Remove shim
if [ -f "$SHIV_BIN_DIR/$NAME" ]; then
  rm "$SHIV_BIN_DIR/$NAME"
fi

# Deregister
shiv_unregister "$NAME"
shiv_cache_remove "$NAME"

# Clean up package directory
if [ -d "$TOOL_PATH" ]; then
  case "$TOOL_PATH" in
    "$SHIV_PACKAGES_DIR"/*)
      # Index-installed — safe to remove if working tree is clean
      repo_dirty=false
      if [ -n "$(git -C "$TOOL_PATH" status --porcelain 2>/dev/null | head -1)" ]; then
        repo_dirty=true
      fi
      if git -C "$TOOL_PATH" rev-parse --verify @{upstream} &>/dev/null; then
        if [ -n "$(git -C "$TOOL_PATH" log @{upstream}..HEAD --oneline 2>/dev/null | head -1)" ]; then
          repo_dirty=true
        fi
      else
        # No upstream tracking — can't verify commits are pushed, be conservative
        repo_dirty=true
      fi

      if [ "$repo_dirty" = "true" ] && [ "$FORCE" != "true" ]; then
        echo ""
        gum style --faint "  Package directory has local changes, retained at $TOOL_PATH"
        gum style --faint "  Use --force to remove it."
      else
        rm -rf "$TOOL_PATH"
      fi
      ;;
    *)
      # Local-path install — never remove, it's the user's repo
      echo ""
      gum style --faint "  Package directory retained at $TOOL_PATH"
      ;;
  esac
fi

echo ""
echo "  ✓ Uninstalled $NAME"
