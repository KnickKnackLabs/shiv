#!/usr/bin/env bash
#MISE description="Install a tool — from the package index or a local path"
#USAGE arg "<name>" help="Package name, optionally with ref (e.g., shimmer, frames@v1.0.0)"
#USAGE arg "[path]" help="Local path to repo (optional — if omitted, clones from package index)"
#USAGE flag "--as <alias>" var=#true help="Command alias(es) — creates symlinks to the package shim"
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$REPO_DIR/lib/shim.sh"

NAME="${usage_name}"
LOCAL_PATH="${usage_path:-}"

# Parse name@ref syntax
REF=""
if [[ "$NAME" == *@* ]]; then
  REF="${NAME#*@}"
  NAME="${NAME%%@*}"
fi

# Collect aliases from --as flags (var=#true gives space-separated string)
ALIASES=()
if [ -n "${usage_as:-}" ]; then
  IFS=' ' read -ra ALIASES <<< "$usage_as"
fi

if [ -n "$LOCAL_PATH" ]; then
  # Local install — point at an existing repo
  if [ -n "$REF" ]; then
    echo "Error: @ref syntax is not supported with local path installs" >&2
    exit 1
  fi
  TOOL_PATH="$(cd "$LOCAL_PATH" && pwd)"
else
  # Package install — look up in sources and clone
  GH_REPO=$(shiv_lookup "$NAME")
  if [ -z "$GH_REPO" ]; then
    echo "Error: '$NAME' not found in package index" >&2
    echo ""
    echo "Available packages:"
    shiv_list_sources | while read -r pkg repo; do
      echo "  $pkg → $repo"
    done
    exit 1
  fi

  # Detect ref type if a ref was specified
  REF_TYPE=""
  if [ -n "$REF" ]; then
    REF_TYPE=$(shiv_detect_ref_type "$GH_REPO" "$REF") || exit 1
  fi

  TOOL_PATH="$SHIV_PACKAGES_DIR/$NAME"

  # If already cloned but ref changed, re-clone
  if [ -d "$TOOL_PATH" ]; then
    EXISTING_REF=$(shiv_registry_ref "$NAME")
    if [ "$REF" != "$EXISTING_REF" ]; then
      echo "Ref changed (${EXISTING_REF:-default} → ${REF:-default}), re-cloning..."
      rm -rf "$TOOL_PATH"
    fi
  fi

  if [ -d "$TOOL_PATH" ]; then
    # Already cloned, same ref
    echo "Already cloned: $TOOL_PATH"
    if git -C "$TOOL_PATH" symbolic-ref HEAD &>/dev/null; then
      echo "Pulling latest..."
      git -C "$TOOL_PATH" pull --ff-only 2>&1 | sed 's/^/  /'
    else
      echo "  Pinned to ${REF} — skipping pull"
    fi
  else
    echo "Cloning $GH_REPO${REF:+@$REF}..."
    mkdir -p "$SHIV_PACKAGES_DIR"
    case "$REF_TYPE" in
      "")
        gh repo clone "$GH_REPO" "$TOOL_PATH" -- --single-branch 2>&1 | sed 's/^/  /'
        ;;
      branch)
        gh repo clone "$GH_REPO" "$TOOL_PATH" -- --branch "$REF" --single-branch 2>&1 | sed 's/^/  /'
        ;;
      tag)
        gh repo clone "$GH_REPO" "$TOOL_PATH" -- --branch "$REF" --depth 1 --single-branch 2>&1 | sed 's/^/  /'
        ;;
      commit)
        gh repo clone "$GH_REPO" "$TOOL_PATH" 2>&1 | sed 's/^/  /'
        git -C "$TOOL_PATH" checkout "$REF" 2>&1 | sed 's/^/  /'
        ;;
    esac
  fi

  # Set up dependencies
  echo "Setting up..."
  (cd "$TOOL_PATH" && mise trust -q 2>/dev/null; mise install -q 2>/dev/null) || true
fi

if [ ! -f "$TOOL_PATH/mise.toml" ]; then
  echo "Warning: no mise.toml found at $TOOL_PATH"
fi

shiv_create_shim "$NAME" "$TOOL_PATH"
SHIV_REF="$REF" shiv_register "$NAME" "$TOOL_PATH" "${ALIASES[@]}"
shiv_cache_tasks "$NAME" "$TOOL_PATH"

# Create alias symlinks
if [ ${#ALIASES[@]} -gt 0 ]; then
  shiv_create_alias_symlinks "$NAME" "${ALIASES[@]}"
fi

echo ""
echo "✓ Installed: $NAME${REF:+@$REF} → $TOOL_PATH"
echo "  Shim: $SHIV_BIN_DIR/$NAME"
if [ -n "$REF" ]; then
  echo "  Ref: $REF ($REF_TYPE)"
fi
if [ ${#ALIASES[@]} -gt 0 ]; then
  echo "  Aliases: ${ALIASES[*]}"
fi
echo ""
echo "Reload your shell or run:"
echo "  eval \"\$(mise -C $REPO_DIR run -q shell)\""
